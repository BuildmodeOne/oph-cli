{
  "name": "oph",
  "version": "2.0.3",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "node scripts/gen-version.js",
    "build": "tsc && tsc-alias",
    "build:bin": "node scripts/gen-version.js && tsc && tsc-alias && esbuild dist/index.js --bundle --platform=node --target=node22 --outfile=dist/bundle.js && pkg dist/bundle.js -t node22 --no-bytecode --public-packages \"*\" --public -o bin/oph",
    "start": "node dist/index.js",
    "check": "tsc --noEmit && biome check",
    "check:fix": "tsc --noEmit && biome check --fix"
  },
  "bin": {
    "oph": "dist/index.js"
  },
  "keywords": [],
  "author": "Philipp Opheys",
  "license": "ISC",
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d",
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "commander": "^14.0.3",
    "cross-spawn": "^7.0.6",
    "ignore": "^7.0.5",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^25.9.1",
    "@yao-pkg/pkg": "^6.19.0",
    "esbuild": "^0.28.0",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.9.3"
  }
}
